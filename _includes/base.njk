<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Open Drafts — Research Colloquium</title>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
  <style>
    @font-face {
      font-family: 'NaNTragedy';
      src: url('fonts/NaNTragedyDisplay-Black.woff2') format('woff2');
      font-weight: 900;
    }
    @font-face {
      font-family: 'NaNTragedy';
      src: url('fonts/NaNTragedyDisplay-Regular.woff2') format('woff2');
      font-weight: 400;
    }
    @font-face {
      font-family: 'NaNSerfB';
      src: url('fonts/NaNSerfBDisplay-Black-TRIAL.ttf') format('truetype');
      font-weight: 900;
    }
    @font-face {
      font-family: 'NaNSerfB';
      src: url('fonts/NaNSerfBDisplay-Medium-TRIAL.ttf') format('truetype');
      font-weight: 500;
    }
    @font-face {
      font-family: 'NaNHolo';
      src: url('fonts/NaNHolo_TRIAL-Regular.ttf') format('truetype');
      font-weight: 400;
    }
    @font-face {
      font-family: 'NaNHolo';
      src: url('fonts/NaNHolo_TRIAL-Medium.ttf') format('truetype');
      font-weight: 500;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root { --bg: #f9f9f8; }

    html { font-size: 16px; }

    body {
      background: var(--bg);
      color: #111;
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      line-height: 1.5;
      padding: 2.5rem 2.5rem 6rem;
    }

    /* ── 16-col grid ── */
    .page-grid {
      display: grid;
      grid-template-columns: repeat(16, 1fr);
      column-gap: 1rem;
    }

    /* ── Header ── */
    .header-line {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid #111;
      margin-bottom: 1.75rem;
    }
    h1 {
      font-family: 'NaNHolo', sans-serif;
      font-weight: 500;
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      line-height: 0.95;
      letter-spacing: -0.01em;
      color: #111;
    }
    .tagline {
      font-size: 1rem;
      color: #111;
      white-space: nowrap;
      padding-bottom: 0.15em;
    }

    /* ── Coloured square date tags ── */
    .tag-date {
      border-radius: 99px;
      border-color: transparent;
      padding: 0.18rem 0.55rem;
      font-size: 0.65rem;
      letter-spacing: 0.04em;
    }
    /* Each colour + its readable text — M&X palette */
    .c1  { background: #A0B0FF; color: #111; }   /* Blueberry     */
    .c2  { background: #FC6B44; color: #fff; }   /* Mandarine     */
    .c3  { background: #60BB4D; color: #fff; }   /* Kiwi          */
    .c4  { background: #CFDD47; color: #111; }   /* Lime          */
    .c5  { background: #F277E1; color: #111; }   /* Guava         */
    .c6  { background: #9FCCF4; color: #111; }   /* Candy         */
    .c7  { background: #BD5C2F; color: #fff; }   /* Cinnamon      */
    .c8  { background: #A0B0FF; color: #111; }   /* Blueberry ×2  */
    .c9  { background: #FC6B44; color: #fff; }   /* Mandarine ×2  */

    /* ── Intro row — 16-col grid ── */
    .intro-row {
      display: grid;
      grid-template-columns: repeat(16, 1fr);
      column-gap: 1rem;
      align-items: start;
      margin-bottom: 3.5rem;
    }
    /* first two "live" paras: cols 1–4 */
    .intro-col-a {
      grid-column: 1 / 5;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    /* "We convene…" + "All sessions…": cols 5–8 */
    .intro-col-b {
      grid-column: 5 / 9;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    /* HfG meta: far right col 16 */
    .intro-meta {
      grid-column: 16 / 17;
      font-family: 'NaNHolo', sans-serif;
      font-size: 0.75rem;
      font-weight: 500;
      color: #111;
      text-align: right;
      white-space: nowrap;
      padding-top: 0.1rem;
      line-height: 1.4;
    }
    .intro-meta a { color: #111; text-decoration: none; }
    .intro-meta a:hover { text-decoration: underline; }

    .intro-col-a p,
    .intro-col-b p {
      font-size: 0.8rem;
      line-height: 1.75;
      color: #111;
      text-wrap: pretty;
      orphans: 3;
      widows: 3;
    }

    /* ── Archive heading ── */
    .archive-heading {
      font-family: 'NaNHolo', sans-serif;
      font-weight: 500;
      font-size: 1.5rem;
      color: #111;
      margin-top: 3rem;
      margin-bottom: 1rem;
    }

    /* ── Semester label ── */
    .semester-label {
      font-size: 0.88rem;
      letter-spacing: 0.01em;
      color: #111;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid #111;
      margin-bottom: 0;
    }

    /* ── Table ── */
    .session-table { list-style: none; margin-bottom: 3.5rem; }

    .session-row { border-bottom: 1px solid #ddd; }
    .session-row.has-detail { cursor: pointer; }
    .session-row.has-detail .row-main:hover { background: rgba(0,0,0,0.02); }

    .row-main {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      padding: 0.6rem 0;
    }

    .row-num {
      font-size: 0.88rem;
      font-weight: 400;
      color: #111;
      min-width: 2.2rem;
      line-height: 1;
    }

    /* ── Up Next styling — apply .is-upnext to the <li> to activate ── */
    .is-upnext .row-num {
      position: relative;
      color: #111;
    }
    .is-upnext .row-num::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 0.55rem;
      transform: translate(-50%, -50%);
      width: 1.7rem;
      height: 1.7rem;
      background: var(--accent, #60BB4D);
      border-radius: 50%;
      pointer-events: none;
      z-index: -1;
    }
    .is-upnext .upnext-label {
      font-size: 0.7rem;
      color: color-mix(in srgb, var(--accent, #60BB4D) 65%, #000 35%);
      font-style: normal;
    }

    .row-name {
      flex: 1;
      font-size: 0.95rem;
      color: #111;
    }
    .row-name a { color: #111; text-decoration: none; }
    .row-name a:hover { text-decoration: underline; }
    .row-name em { font-style: italic; }
    .row-name.muted { color: #999; }

    /* ── Tag group ── */
    .row-tags {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      flex-shrink: 0;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid #111;
      border-radius: 99px;
      font-size: 0.75rem;
      letter-spacing: 0.04em;
      padding: 0.18rem 0.55rem;
      color: #111;
      white-space: nowrap;
      line-height: 1;
    }

    /* action buttons — same pill style but interactive */
    button.tag {
      background: none;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
      min-height: calc(0.75rem + 0.36rem);
    }
    button.tag:hover {
      background: #111;
      color: #fff;
    }
    button.tag.open {
      background: #111;
      color: #fff;
    }
    button.tag[title="Notes"] { font-size: 0.9rem; }

    /* grid icon for photos button */
    .grid-icon {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      width: 8px;
      height: 8px;
    }
    .grid-icon span { background: currentColor; display: block; border-radius: 0.5px; }

    /* ── Expandable detail ── */
    .row-detail {
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.4s ease;
    }
    .row-detail.open { max-height: 900px; }

    .detail-inner {
      padding: 0.75rem 0 1.25rem 3.5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem 2.5rem;
    }
    .detail-inner.photos-only { grid-template-columns: 1fr; }

    .detail-text {
      font-size: 0.8rem;
      line-height: 1.8;
      color: #111;
    }
    .detail-text em { font-style: italic; }

    .detail-photos {
      display: flex;
      gap: 0.4rem;
      align-items: flex-start;
      max-width: 360px;
    }
    .detail-photos img {
      width: calc(33.33% - 0.27rem);
      aspect-ratio: 4/3;
      object-fit: cover;
      cursor: zoom-in;
      transition: opacity 0.2s;
      flex-shrink: 0;
    }
    .detail-photos img:hover { opacity: 0.8; }

    /* ── Bottom row ── */
    .bottom-row {
      display: grid;
      grid-template-columns: repeat(16, 1fr);
      column-gap: 1rem;
      border-top: 1px solid #111;
      padding-top: 1.5rem;
      margin-top: 0.5rem;
      align-items: start;
    }
    .bottom-contact {
      grid-column: 1 / 5;
      font-size: 0.8rem;
      color: #111;
    }
    .bottom-contact p { margin-bottom: 0.35rem; }
    .bottom-contact a { color: #111; text-decoration: underline; }
    .bottom-contact a:hover { opacity: 0.6; }
    .bottom-meta {
      grid-column: 16 / 17;
      font-family: 'NaNHolo', sans-serif;
      font-size: 0.75rem;
      font-weight: 500;
      color: #111;
      text-align: right;
      white-space: nowrap;
      line-height: 1.4;
    }
    .bottom-meta a { color: #111; text-decoration: none; }
    .bottom-meta a:hover { text-decoration: underline; }

    /* ── Lightbox ── */
    .lightbox {
      display: none; position: fixed; inset: 0; z-index: 1000;
      align-items: center; justify-content: center; cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox-backdrop {
      position: absolute; inset: 0;
      background: rgba(247,248,250,0.22);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .lightbox-inner {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      animation: lb-in 0.2s ease;
    }
    .lightbox img {
      width: min(520px, 65vw); height: auto;
      border-radius: 4px;
      box-shadow: 0 6px 32px rgba(0,0,0,0.15);
    }
    .lightbox-caption {
      font-size: 0.7rem;
      color: #111;
      margin-top: 0.4rem;
      text-align: right;
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      pointer-events: none;
    }
    @keyframes lb-in {
      from { opacity: 0; transform: scale(0.96); }
      to   { opacity: 1; transform: scale(1); }
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .intro-row {
        grid-template-columns: 1fr 1fr;
        row-gap: 1.5rem;
      }
      .intro-col-a { grid-column: 1 / 2; }
      .intro-col-b { grid-column: 2 / 3; }
      .intro-meta   { grid-column: 1 / 3; text-align: left; }

      .bottom-row { grid-template-columns: 1fr 1fr; }
      .bottom-contact { grid-column: 1 / 2; }
      .bottom-meta { grid-column: 2 / 3; text-align: right; }
    }

    @media (max-width: 600px) {
      body { padding: 1.25rem 1rem 5rem; }

      /* Stack header title + tagline vertically */
      .header-line {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
      }
      h1 { font-size: clamp(2.2rem, 12vw, 3.5rem); margin-bottom: 0; }
      .tagline { white-space: normal; font-size: 0.9rem; }

      .intro-row, .bottom-row {
        grid-template-columns: 1fr;
        row-gap: 1rem;
      }
      .intro-col-a,
      .intro-col-b,
      .intro-meta { grid-column: 1 / 2; text-align: left; }
      .bottom-contact,
      .bottom-meta { grid-column: 1 / 2; text-align: left; }

      .row-main {
        display: grid;
        grid-template-columns: 2.2rem 1fr;
        grid-template-rows: auto auto;
        column-gap: 0.75rem;
        row-gap: 0.35rem;
        align-items: start;
        padding: 0.85rem 0;
      }
      .row-num  { grid-column: 1; grid-row: 1 / 3; align-self: center; }
      .row-name { grid-column: 2; grid-row: 1; font-size: 0.85rem; }
      .row-tags { grid-column: 2; grid-row: 2; flex-wrap: wrap; gap: 0.25rem; }
      .tag { font-size: 0.75rem; }

      .detail-inner { padding-left: 0; grid-template-columns: 1fr; }
      .detail-photos { max-width: 100%; }
    }

    @media (max-width: 400px) {
      .tag-affil { display: none; }
    }
  </style>
</head>
<body>

{{ content | safe }}

<!-- Lightbox -->
<div class="lightbox" id="lightbox" onclick="closeLightbox()">
  <div class="lightbox-backdrop"></div>
  <div class="lightbox-inner">
    <img id="lightbox-img" src="" alt="">
    <span class="lightbox-caption" id="lightbox-caption"></span>
  </div>
</div>

<script>
  function toggleExpand(rowId) {
    const el = document.getElementById(rowId + '-expand');
    if (!el) return;
    const btn = document.querySelector(`#${rowId} button[title="Notes"]`);
    const isOpen = el.classList.toggle('open');
    if (btn) btn.classList.toggle('open', isOpen);
  }

  function togglePhotos(rowId) {
    const el = document.getElementById(rowId + '-photos');
    if (!el) return;
    const btn = document.querySelector(`#${rowId} button[title="Photos"]`);
    const isOpen = el.classList.toggle('open');
    if (btn) btn.classList.toggle('open', isOpen);
  }

  function openLightbox(src, caption) {
    document.getElementById('lightbox-img').src = src;
    document.getElementById('lightbox-caption').textContent = caption || '';
    document.getElementById('lightbox').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    document.getElementById('lightbox').classList.remove('open');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>
</body>
</html>
